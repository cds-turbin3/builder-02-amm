#!/usr/bin/env bash
#
# Pre-commit hook: enforces formatting and lint cleanliness.
# Activated via `git config core.hooksPath .githooks`.
#
# To skip in an emergency: `git commit --no-verify` (avoid as a habit).

set -euo pipefail

echo "==> cargo fmt --all --check"
cargo fmt --all -- --check

echo "==> cargo clippy --all-targets -- -D warnings"
cargo clippy --all-targets --no-deps -- -D warnings

echo "==> cargo clippy --all-targets --features amm/test-helpers -- -D warnings"
cargo clippy --all-targets --no-deps --features amm/test-helpers -- -D warnings

echo "==> pre-commit checks passed"
